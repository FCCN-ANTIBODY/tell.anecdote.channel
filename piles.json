---
# Build-time manifest: renders the fronted-pile registry to a small, cacheable JSON
# list — a public transparency/discovery projection. The feed itself needs no
# resolver: a pile's chain is served at piles/<id>/feed/* (disk path == URL path).
# No network IO at build.
layout: null
permalink: /piles.json
---
{%- assign piles = site.data.piles -%}
[
{%- for pile in piles -%}
  {
    "id": {{ pile.id | jsonify }},
    "scope": {{ pile.scope | jsonify }},
    "feed": {{ "piles/" | append: pile.id | append: "/feed/" | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
