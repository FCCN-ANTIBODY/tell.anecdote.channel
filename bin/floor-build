#!/usr/bin/env bash
# Build the Floor as its OWN GitHub Pages site (anecdote.channel#93).
#
# `bin/floor-build [outdir]` emits a complete, ready-to-publish Pages site —
# the three template files plus a CNAME — into <outdir> (default: _floor).
# This is a separate site output from the Jekyll build on purpose: the Floor
# is one canonical Pages site of its own, and every made-up
# <name>.tell.anecdote.channel is masked onto it at the edge (wildcard DNS,
# proxied; the masking is DNS/edge configuration, not a repo concern).
#
# The CNAME carries the ONE canonical hostname (default
# floor.tell.anecdote.channel — itself just another name under the same
# wildcard; calling it up directly gets the same blank slate as any name,
# because the page can't do anything else). Override with FLOOR_CNAME.
#
# Nothing is ever provisioned per name. The output is static, constant, and
# public — the server it lands on has no obligations other than delivering it.
set -euo pipefail
here="$(cd "$(dirname "$0")/.." && pwd)"
out="${1:-$here/_floor}"
cname="${FLOOR_CNAME:-floor.tell.anecdote.channel}"

mkdir -p "$out"
cp "$here/floor/index.html" "$out/index.html"
cp "$here/floor/floor.mjs" "$out/floor.mjs"
cp "$here/floor/sw.js" "$out/sw.js"

# The storage-adapter PIN: the Anecdote platform identity's PUBLIC fingerprint (key:sha256:…), stamped into the
# static site at build. It is a VERIFICATION key, never a secret (like keys/*.fpr), so it lives in the clear —
# not a GitHub Secret, not a runtime env at serve time (there is no server). Source, in precedence order:
# $FLOOR_PLATFORM_KEY, else keys/anecdote.fpr. Absent → the built pin stays null and the adapter is inert (the
# safe default). Present-but-malformed → the build FAILS rather than shipping a broken pin.
fpr="${FLOOR_PLATFORM_KEY:-}"
if [ -z "$fpr" ] && [ -f "$here/keys/anecdote.fpr" ]; then
  fpr="$(tr -d '[:space:]' < "$here/keys/anecdote.fpr")"
fi
if [ -n "$fpr" ]; then
  [[ "$fpr" =~ ^key:sha256:[0-9a-f]{64}$ ]] || { echo "floor-build: pin must be a key:sha256:<64-hex> fingerprint (got: ${fpr:0:24}…)" >&2; exit 1; }
  sed "s#export const PLATFORM_KEY = null;#export const PLATFORM_KEY = \"$fpr\";#" "$here/floor/pin.mjs" > "$out/pin.mjs"
  grep -q "\"$fpr\"" "$out/pin.mjs" || { echo "floor-build: failed to stamp the pin into pin.mjs" >&2; exit 1; }
  echo "floor-build: pinned Anecdote platform identity ${fpr:0:20}…" >&2
else
  cp "$here/floor/pin.mjs" "$out/pin.mjs"
  echo "floor-build: no pin set (FLOOR_PLATFORM_KEY / keys/anecdote.fpr) — adapter inert" >&2
fi
# The storage-adapter consumer bootstrap (the glove): the floor's own machinery to install, verify against the
# pin, and drive an engine's delivered client. Static like the rest — no per-name provisioning. See
# floor/adapter/MIRROR.md.
mkdir -p "$out/adapter"
cp "$here"/floor/adapter/*.mjs "$out/adapter/"
printf '%s\n' "$cname" > "$out/CNAME"
# Pages must not run the output through Jekyll — serve the bytes as-is.
: > "$out/.nojekyll"

echo "floor site built: $out (CNAME: $cname)" >&2
