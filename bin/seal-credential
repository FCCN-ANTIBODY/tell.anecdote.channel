#!/usr/bin/env node
// Mint (or peek at) a sealed submission credential — docs/sealed-credential.md's "mint gesture",
// runnable wherever the operator holds TELL_SEAL_KEY (never a page that ships the secret).
//
//   TELL_SEAL_KEY=... bin/seal-credential --token ghp_x --repo owner/name --issue 7 --pile p --poll q
//   TELL_SEAL_KEY=... bin/seal-credential --peek sc1....        (binding only; the token stays sealed away)
//   bin/seal-credential --mint-key                              (a fresh 32-byte sealing secret)
import { seal, unseal, mintKey } from "../workers/submit-gateway/seal.mjs";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";
process.chdir(join(dirname(fileURLToPath(import.meta.url)), ".."));

const args = {};
const argv = process.argv.slice(2);
for (let i = 0; i < argv.length; i++) if (argv[i].startsWith("--")) args[argv[i].slice(2)] = argv[i + 1] ?? true;

if (args["mint-key"]) { console.log(mintKey()); process.exit(0); }
const key = process.env.TELL_SEAL_KEY;
if (!key) { console.error("seal-credential: set TELL_SEAL_KEY (bin/seal-credential --mint-key)"); process.exit(1); }
if (args.peek) {
  const b = await unseal(args.peek, key);
  if (!b) { console.error("cipher does not open here"); process.exit(1); }
  const { token, ...binding } = b;
  console.log(JSON.stringify({ ...binding, token: "(sealed)" }, null, 2));
  process.exit(0);
}
const binding = { token: args.token, repo: args.repo, issue: String(args.issue || ""), pile: args.pile, poll: args.poll,
                  minted_at: args["minted-at"] || new Date().toISOString() };
console.log(await seal(binding, key));
