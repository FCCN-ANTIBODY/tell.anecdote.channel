#!/usr/bin/env bash
# Inbound-digest rollup hook — the pluggable seam the deliver pipeline calls per pile.
#
# `bin/rollup <id> [scope]` prints this window's plaintext digest on stdout; deliver
# seals it as ONE encrypted, hash-linked, signed block. Empty stdout = "nothing new
# this window" → deliver skips the pile (no empty block).
#
# Default behavior: emit the authorized submissions bin/collect-submissions staged for
# this pile under $TELL_SUBMISSIONS_DIR/<id>/ — i.e. the responses Tell received as
# Issues and authorized. Each block is the window's batch of accepted answers, stamped
# with the issue number that carried each (a literal ingress→egress custody record).
#
# Override entirely by replacing this file or setting TELL_ROLLUP_CMD (same contract).
set -euo pipefail
id="${1:?usage: bin/rollup <id> [scope]}"
scope="${2:-}"
here="$(cd "$(dirname "$0")" && pwd)"
stage="${TELL_SUBMISSIONS_DIR:-$(cd "$here/.." && pwd)/.submissions}/$id"

# No staged submissions for this pile this window → emit nothing (deliver skips).
ls "$stage"/*.json >/dev/null 2>&1 || exit 0

# Fold the accepted answers into one record. `records` preserves the issue number that
# carried each answer, so the owner's decrypted tank shows exactly what arrived and from
# which submission.
records="$(jq -s '[.[] | {issue: .number, round: .round, answer: .answer, ts: .ts}]' "$stage"/*.json)"
jq -n \
  --arg id "$id" \
  --arg scope "$scope" \
  --arg at "$(date -u +%FT%TZ)" \
  --argjson records "$records" '
  {
    schema: "tell.digest/v0",
    pile: $id,
    scope: $scope,
    window_end: $at,
    count: ($records | length),
    records: $records
  }'
