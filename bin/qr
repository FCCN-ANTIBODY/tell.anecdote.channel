#!/usr/bin/env bash
# Mint an authorized QR for a specific POLL on a pile this Tell fronts. A pile can host
# many polls (an open question, an unsolicited broadcast, a sensor-checked dropbox, …);
# the token binds {pile, poll, round} so a scan can't be retargeted to another poll.
# The landing the URL opens carries the poll config + the token bin/authz verifies.
#
#   bin/qr --pile ID --poll POLL [--round 1] [--type open] [--asker ADDR] \
#          [--question Q] [--opts CSV] [--repo OWNER/NAME] [--signkey PATH]
#
#     --round    bump to expire/rotate an outstanding QR for this poll
#     --type     poll type (carried, not bound) — routing hint for the pile/runner
#     --asker    originating asker address (carried, not bound) — who posed the poll
#     --question / --opts   shown on the landing (open-question type)
#     --repo     this jurisdiction Tell's GitHub repo (carried, not bound) — the mailbox
#                the landing addresses the reply to. Defaults to $TELL_REPO; when blank the
#                landing falls back to its canonical repo. A QR minted on the shared
#                tell.anecdote.channel domain can thus address YOUR Tell
#                (tell.antibody.fort-collins.colorado.anecdote.channel -> its repo). It is
#                unbound metadata: a foreign Tell rejects a token it did not mint.
#     --signkey  ssh signing key (path, or pass key material via TELL_SIGNER_KEY) to add a
#                PROVENANCE signature over the exact payload — `sig` (+ signer id `kid`).
#                The token authorizes a reply into THIS Tell's mailbox; the signature proves
#                the QR's origin + integrity to ANYONE with the signer's public key,
#                registry-free (the "worth processing at all" gate). Omit => unsigned QR.
#                Same ssh-keygen -Y primitive bin/deliver uses; see docs/qr-provenance.md.
#
# Needs TELL_QR_SECRET (the master secret; bin/tell-bootstrap generates it). The signature
# is optional and additive. With qrencode present, also writes a PNG.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
. "$here/tell-lib.sh"

pile=""; poll=""; round="1"; type="open"; asker=""; question=""; opts=""; guidance=""; repo="${TELL_REPO:-}"
signkey_arg=""; mode="comment"; canonical=""; run=""; submit_url="${TELL_SUBMIT_URL:-}"
while [ $# -gt 0 ]; do
  case "$1" in
    --pile) pile="$2"; shift 2;;
    --poll) poll="$2"; shift 2;;
    --round) round="$2"; shift 2;;
    --type) type="$2"; shift 2;;
    --asker) asker="$2"; shift 2;;
    --question) question="$2"; shift 2;;
    --opts) opts="$2"; shift 2;;
    --guidance) guidance="$2"; shift 2;;
    --repo) repo="$2"; shift 2;;
    --signkey) signkey_arg="$2"; shift 2;;
    --mode) mode="$2"; shift 2;;          # comment (onto the canonical poll issue) — the paradigm; issue is retired
    --canonical) canonical="$2"; shift 2;; # the canonical poll issue number that comments attach to (bin/open-poll prints it)
    --run) run="$2"; shift 2;;            # a non-secret id telling QRs/runs apart; default derived from the token
    --submit-url) submit_url="$2"; shift 2;; # the Tell's submit-gateway worker (see workers/submit-gateway); supersedes embedding a post credential
    *) echo "bin/qr: unknown arg: $1" >&2; exit 1;;
  esac
done
# mode=issue is RETIRED for every relayed/credentialed path (docs/sealed-credential.md → "What it
# forces, usefully"): the comment paradigm is the paradigm — one poll, one canonical issue
# (bin/open-poll), every reply a comment on it. The one legitimate new-issue path left is the
# credential-free issueUrl fallback on the runtime, where the respondent's own click is the authority.
case "$mode" in
  comment) ;;
  issue) echo "bin/qr: --mode issue is retired — open the poll's canonical issue (bin/open-poll) and mint --canonical <issue#>; the credential-free issueUrl fallback is the one new-issue path left" >&2; exit 1;;
  *) echo "bin/qr: --mode must be comment (got: $mode)" >&2; exit 1;;
esac
if [ -n "$canonical" ] && ! printf '%s' "$canonical" | grep -Eq '^[0-9]+$'; then
  echo "bin/qr: --canonical must be an issue number (got: $canonical)" >&2; exit 1
fi
# Sanitize repo to OWNER/NAME so it can only ever address a github.com repo path.
if [ -n "$repo" ] && ! printf '%s' "$repo" | grep -Eq '^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$'; then
  echo "bin/qr: --repo must be OWNER/NAME (got: $repo)" >&2; exit 1
fi
# Sanitize the submit URL: https only — it is where the runtime will POST the reply.
if [ -n "$submit_url" ] && ! printf '%s' "$submit_url" | grep -Eq '^https://[A-Za-z0-9.-]+(:[0-9]+)?(/[A-Za-z0-9._/-]*)?$'; then
  echo "bin/qr: --submit-url must be a plain https URL (got: $submit_url)" >&2; exit 1
fi
# A credentialed route (submit= relay or embedded post=) can only ever land a COMMENT on the poll's
# canonical issue — the runtime refuses a credentialed submit with no canonical thread, so minting
# one would mint a dead route. Without --canonical only the issueUrl fallback rides.
if [ -z "$canonical" ] && { [ -n "$submit_url" ] || [ -n "${TELL_POST_TOKEN:-}" ]; }; then
  echo "bin/qr: a credentialed QR (submit=/post=) needs --canonical <issue#> — run bin/open-poll first (a canonical-less QR carries only the issueUrl fallback)" >&2; exit 1
fi
[ -n "$pile" ] && [ -n "$poll" ] || { echo "usage: bin/qr --pile ID --poll POLL [--round R] [--type T] [--asker A] [--question Q] [--opts CSV] [--guidance TEXT] [--signkey PATH]" >&2; exit 1; }
: "${TELL_QR_SECRET:?set TELL_QR_SECRET (see bin/tell-bootstrap)}"
: "${TELL_DOMAIN:=https://tell.anecdote.channel}"

tok="$(tl_token "$TELL_QR_SECRET" "$pile" "$poll" "$round")"
# Default run id: a short, non-secret tag derived from the token so it is stable per
# (pile,poll,round). Pass --run to distinguish several concurrent runs of the same poll.
[ -n "$run" ] || run="${tok:0:12}"

enc() { jq -rn --arg s "$1" '$s|@uri'; }   # URL-encode

# Collect the payload as key=value pairs (values URL-encoded, exactly as they ride in the
# URL). Bound fields first, then unbound routing/render metadata. This same set, run
# through tl_qr_canon, is the preimage the provenance signature covers — so mode/canonical/
# run are provenance-covered too (the credential below is NOT; it is never self-signed).
pairs=( "pile=$(enc "$pile")" "poll=$(enc "$poll")" "round=$(enc "$round")" "tok=${tok}" "type=$(enc "$type")" )
pairs+=( "mode=$(enc "$mode")" "run=$(enc "$run")" )
[ -n "$canonical" ] && pairs+=( "canonical=$(enc "$canonical")" )
[ -n "$asker" ]    && pairs+=( "asker=$(enc "$asker")" )
[ -n "$question" ] && pairs+=( "q=$(enc "$question")" )
[ -n "$opts" ]     && pairs+=( "opts=$(enc "$opts")" )
[ -n "$guidance" ] && pairs+=( "guidance=$(enc "$guidance")" )
[ -n "$repo" ]     && pairs+=( "repo=$(enc "$repo")" )

# The SUBMIT URL (preferred) or POST CREDENTIAL (legacy): how a respondent with no GitHub
# account gets their reply posted.
#
# `submit=` — the Tell's own submit-gateway worker (workers/submit-gateway): the credential stays
# server-side as a worker secret and the QR carries only a non-secret address. Like `post`, it
# is added AFTER the signature preimage and dropped from canon (tl_qr_canon), so the worker can
# move/rotate without re-minting printed QRs. When set, no credential is embedded.
#
# `post=` — the legacy QR-embedded credential: CARRIED here, never MINTED here — set
# $TELL_POST_TOKEN from a repo-scoped, issues-only, short-expiry fine-grained PAT. Semi-public
# by design (it rides in the QR); keep its scope tiny. Superseded by the worker; kept for
# workers-less deployments (see docs/submission-credential.md).
post_pair=""; submit_pair=""
if [ -n "$submit_url" ]; then
  submit_pair="submit=$(enc "$submit_url")"
  if [ -n "${TELL_POST_TOKEN:-}" ]; then
    echo "bin/qr: note — --submit-url set; NOT embedding TELL_POST_TOKEN (the worker holds it)" >&2
  fi
elif [ -n "${TELL_POST_TOKEN:-}" ]; then
  post_pair="post=$(enc "$TELL_POST_TOKEN")"
  echo "bin/qr: WARN embedding a semi-public POST credential in the QR (repo-scoped/short-lived only; see docs/issue-ingress.md); prefer --submit-url (workers/submit-gateway)" >&2
fi

# Provenance signature (optional, additive). Sign the canonical preimage with the Tell's
# delivery signer — the same ssh-keygen -Y primitive bin/deliver uses, under TL_QR_SIG_NS
# so a manifest signature can never be replayed as a poll one. Key from --signkey (a path)
# or TELL_SIGNER_KEY (a path, or the CI secret's key material). See docs/qr-provenance.md.
signkey="${signkey_arg:-${TELL_SIGNER_KEY:-}}"
sig=""; kid=""
if [ -n "$signkey" ]; then
  if command -v ssh-keygen >/dev/null 2>&1; then
    keyfile="$signkey"; tmpkey=""
    if [ ! -f "$keyfile" ]; then                 # not a path => treat as key material
      tmpkey="$(mktemp)"; printf '%s\n' "$signkey" > "$tmpkey"; keyfile="$tmpkey"  # mktemp is 0600
    fi
    sigtmp="$(mktemp)"
    if printf '%s\n' "${pairs[@]}" | tl_qr_canon | ssh-keygen -Y sign -n "$TL_QR_SIG_NS" -f "$keyfile" >"$sigtmp" 2>/dev/null; then
      sig="$(base64 -w0 < "$sigtmp")"
      kid="$(ssh-keygen -lf "$keyfile" 2>/dev/null | awk '{print $2}' || true)"
      [ -n "$kid" ] || kid="$(ssh-keygen -y -f "$keyfile" 2>/dev/null | ssh-keygen -lf - 2>/dev/null | awk '{print $2}' || true)"
    else
      echo "bin/qr: WARN signing failed (bad --signkey/TELL_SIGNER_KEY?); emitting unsigned QR" >&2
    fi
    rm -f "$sigtmp"; [ -n "$tmpkey" ] && rm -f "$tmpkey"
  else
    echo "bin/qr: WARN ssh-keygen not found; emitting unsigned QR (no provenance)" >&2
  fi
else
  echo "bin/qr: note — no --signkey/TELL_SIGNER_KEY; QR carries no provenance signature" >&2
fi
[ -n "$sig" ] && pairs+=( "sig=$(enc "$sig")" "kid=$(enc "$kid")" )
# The submit address / credential ride AFTER the signature preimage and are dropped by
# tl_qr_canon, so they are never part of the signed payload (moving the worker or rotating
# the credential doesn't break provenance).
[ -n "$submit_pair" ] && pairs+=( "$submit_pair" )
[ -n "$post_pair" ] && pairs+=( "$post_pair" )

# Assemble the URL from the (possibly signed) pairs, preserving order.
url="${TELL_DOMAIN}/?$(IFS='&'; printf '%s' "${pairs[*]}")"

echo "$url"
if command -v qrencode >/dev/null 2>&1; then
  out="qr-${pile}-${poll}-${round}.png"
  qrencode -o "$out" "$url" && echo "wrote $out" >&2
else
  echo "note: qrencode not installed — encode the URL above into a QR yourself" >&2
fi
